{
	"name": "adrianjost-cv",
	"version": "3.1.0",
	"description": "Personal Homepage of Adrian Jost. You can find most of his project work and his contact information. If you are impressed you could even offer him a nice Job. ;) He would be very happy to hear from you!",
	"author": "Adrian Jost",
	"license": "MIT",
	"scripts": {
		"dev": "nuxt dev",
		"analyze": "nuxt build --analyze",
		"build": "cross-env NODE_ENV=production nuxt generate",
		"deploy": "npm run lint && npm run build && firebase deploy",
		"test:build": "start-test test:build:mockserver http://localhost:5001 test:build:nuxt",
		"test:build:mockserver": "mockserver -p 5001 -m ./test/mocks",
		"test:build:nuxt": "cross-env API_URL=http://localhost:5001 npm run build",
		"test:snapshot:serve": "npx serve --no-clipboard --listen 4001 .output/public",
		"test:snapshot:playwright": "playwright test",
		"test:snapshot": "start-test test:snapshot:serve http://localhost:4001 test:snapshot:playwright",
		"test": "npm run test:build && npm run test:snapshot",
		"lint:eslint": "eslint --fix",
		"lint:stylelint": "stylelint --fix",
		"lint:prettier": "prettier --write --log-level warn",
		"lint:all:eslint": "npm run lint:eslint -- --ext .js,.vue .",
		"lint:all:stylelint": "npm run lint:stylelint \"src/**/*.{vue,sass,scss,css}\"",
		"lint:all:prettier": "npm run lint:prettier \"**/*.{js,json,css,scss,vue,html}\"",
		"lint": "run-s lint:all:*",
		"postinstall": "playwright install chromium"
	},
	"gitHooks": {
		"pre-commit": "cross-env PRE_COMMIT=true lint-staged"
	},
	"dependencies": {
		"@vojtechlanka/vue-tags-input": "^3.1.2",
		"autosize": "^6.0.1",
		"fetch-retry": "^6.0.0",
		"firebase": "^12.12.1",
		"marked": "^17.0.6",
		"nuxt": "^4.4.4",
		"postcss": "^8.5.3",
		"vuex": "^4.1.0"
	},
	"devDependencies": {
		"@nuxtjs/pwa": "^3.3.5",
		"@nuxtjs/sitemap": "^8.0.11",
		"@playwright/test": "^1.59.1",
		"core-js": "^3.49.0",
		"cross-env": "^10.1.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "^10.9.0",
		"firebase-tools": "^15.16.0",
		"imagemin-lint-staged": "^0.5.1",
		"lint-staged": "^16.4.0",
		"mockserver": "^3.1.1",
		"npm-run-all": "^4.1.5",
		"playwright-chromium": "^1.59.1",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.3",
		"sass": "^1.99.0",
		"sass-loader": "^16.0.7",
		"serve": "^14.2.6",
		"start-server-and-test": "^3.0.2",
		"stylelint": "^17.9.1",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-recess-order": "^7.7.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"stylelint-scss": "^7.0.0",
		"vue": "^3.5.33",
		"webpack": "^5.106.2",
		"yorkie": "^2.0.0"
	},
	"engines": {
		"node": ">=24"
	}
}
