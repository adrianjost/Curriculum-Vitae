{
	"name": "functions",
	"description": "Cloud Functions for Firebase",
	"license": "MIT",
	"scripts": {
		"lint": "eslint . --fix",
		"serve": "npx -p firebase-tools firebase serve --only functions --port=3001",
		"shell": "npx -p firebase-tools firebase functions:shell",
		"start": "npm run shell",
		"deploy": "npx -p firebase-tools firebase deploy --only functions",
		"logs": "npx -p firebase-tools firebase functions:log"
	},
	"dependencies": {
		"firebase-admin": "^13.7.0",
		"firebase-functions": "^7.2.2",
		"marked": "^17.0.5"
	},
	"devDependencies": {
		"eslint": "^10.1.0",
		"firebase-tools": "^15.13.0"
	},
	"engines": {
		"node": "24"
	}
}
